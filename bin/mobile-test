#!/usr/bin/env python3
"""
mobile-test — AI-driven mobile test agent (iOS + Android).

Uses any OpenAI-compatible vision model to see the device screen,
take actions via idb (iOS) or adb (Android), and save reusable skills.

Commands:
  mobile-test run "open Settings and enable Dark Mode"
  mobile-test run "login to app" --save login
  mobile-test run "open Settings" --platform android
  mobile-test smart login "login to app"     # replay or re-learn
  mobile-test replay login
  mobile-test skills
  mobile-test screenshot [/tmp/out.png]
  mobile-test tap 207 400
  mobile-test devices
  mobile-test test
  mobile-test tunneld                        # iOS: start tunneld daemon
  mobile-test config

Flags (any position):
  --platform ios|android   default: ios
  --serial <device_id>     target specific Android device

Environment (required):
  MOBILE_TEST_BASE    OpenAI-compatible API base URL
  MOBILE_TEST_KEY     API key
  MOBILE_TEST_MODEL   Vision model name

Examples:
  # OpenRouter (gpt-4o)
  export MOBILE_TEST_BASE=https://openrouter.ai/api/v1
  export MOBILE_TEST_KEY=sk-or-v1-...
  export MOBILE_TEST_MODEL=openai/gpt-4o
  mobile-test run "open Safari and go to example.com"

  # Local Ollama (llava)
  export MOBILE_TEST_BASE=http://localhost:11434/v1
  export MOBILE_TEST_KEY=ollama
  export MOBILE_TEST_MODEL=llava:latest
  mobile-test run "open Settings" --platform android
"""
import os
import sys

sys.path.insert(0, os.path.join(os.path.dirname(__file__), ".."))


def main():
    args = sys.argv[1:]

    if not args or args[0] in ("-h", "--help", "help"):
        print(__doc__)
        return

    platform = "ios"
    serial = None
    if "--platform" in args:
        idx = args.index("--platform")
        platform = args[idx + 1]
        args = args[:idx] + args[idx + 2:]
    if "--serial" in args:
        idx = args.index("--serial")
        serial = args[idx + 1]
        args = args[:idx] + args[idx + 2:]

    import agent as ag
    ag.set_platform(platform, serial)

    cmd = args[0] if args else ""

    # ── No-AI commands ───────────────────────────────────────────────────────

    if cmd == "devices":
        import subprocess as _sp
        print("iOS:")
        try:
            r = _sp.run([ag.IDB_PATH, "list-targets"],
                        capture_output=True, text=True, timeout=10)
            print(f"  {r.stdout.strip()}" if r.stdout.strip() else "  (none)")
        except Exception as e:
            print(f"  idb error: {e}")
        print("Android:")
        devs = ag.android_devices()
        for d in devs:
            print(f"  {d}")
        if not devs:
            print("  (none connected)")
        return

    if cmd == "test":
        import base64 as _b64
        if platform == "android":
            devs = ag.android_devices()
            if not devs:
                print("[test] No Android device. Enable USB debugging and connect.")
                return
            print(f"[test] Android: {devs[0]}")
        else:
            print(f"[test] iOS tunneld: {'running' if ag.tunneld_running() else 'not running'}")
            if not ag.tunneld_running():
                print("  → mobile-test tunneld  (start for this session)")
                print("  → see docs/setup-ios.md for auto-start setup")
        try:
            screen = ag.screenshot()
        except RuntimeError as e:
            print(f"[test] FAILED: {e}")
            return
        out = "/tmp/mobile-test-screen.png"
        with open(out, "wb") as f:
            f.write(_b64.b64decode(screen))
        print(f"[test] OK — screenshot {len(screen)} bytes")
        print(f"[test] Saved: {out}")
        try:
            os.system(f"open {out}")
        except Exception:
            pass
        return

    if cmd == "screenshot":
        import base64 as _b64
        out = args[1] if len(args) > 1 else "/tmp/mobile-screen.png"
        screen = ag.screenshot()
        with open(out, "wb") as f:
            f.write(_b64.b64decode(screen))
        print(f"Saved: {out}")
        return

    if cmd == "tap":
        if len(args) < 3:
            print("Usage: mobile-test tap <x> <y>"); sys.exit(1)
        ag.tap(int(args[1]), int(args[2]))
        print(f"Tapped ({args[1]}, {args[2]})")
        return

    if cmd == "skills":
        skills = ag.list_skills()
        if not skills:
            print("No skills saved yet.")
        else:
            print(f"Skills ({len(skills)}):")
            for name in skills:
                s = ag.load_skill(name)
                plat = s.get("platform", "ios")
                steps = len(s.get("steps", []))
                print(f"  [{plat}] {name:30s} — {s['goal']} [{steps} steps, ×{s['uses']}]")
        return

    if cmd == "tunneld":
        if platform != "ios":
            print("tunneld is only needed for iOS.")
            return
        print("Starting tunneld (requires sudo)...")
        import subprocess
        subprocess.run(["sudo", sys.executable, "-m", "pymobiledevice3", "remote", "tunneld"])
        return

    if cmd == "config":
        print(f"Platform : {platform.upper()}")
        print(f"Model    : {os.environ.get('MOBILE_TEST_MODEL', '(not set)')}")
        print(f"Base URL : {os.environ.get('MOBILE_TEST_BASE', '(not set)')}")
        if platform == "ios":
            print(f"tunneld  : {'running' if ag.tunneld_running() else 'not running'}")
        else:
            devs = ag.android_devices()
            print(f"Android  : {devs[0] if devs else 'no device'}")
        return

    # ── AI commands ──────────────────────────────────────────────────────────

    if cmd == "run":
        if len(args) < 2:
            print("Usage: mobile-test run 'goal' [--save skill_name]"); sys.exit(1)
        goal = args[1]
        save_as = args[args.index("--save") + 1] if "--save" in args else None
        sys.exit(0 if ag.run(goal, save_as=save_as) else 1)

    elif cmd == "smart":
        if len(args) < 3:
            print("Usage: mobile-test smart <skill> 'goal'"); sys.exit(1)
        sys.exit(0 if ag.smart_run(args[1], args[2]) else 1)

    elif cmd == "replay":
        if len(args) < 2:
            print("Usage: mobile-test replay <skill>"); sys.exit(1)
        sys.exit(0 if ag.replay_skill(args[1]) else 1)

    else:
        if not cmd.startswith("-"):
            sys.exit(0 if ag.run(" ".join(args)) else 1)
        print(f"Unknown command: {cmd}")
        print(__doc__)
        sys.exit(1)


if __name__ == "__main__":
    main()
